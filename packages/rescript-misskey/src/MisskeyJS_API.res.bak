// API module - Less-common REST operations
// Contains Users, Following, Drive, Meta submodules
// For common operations, use the top-level modules (Notes, Timeline, Notifications, Me)

open MisskeyJS_Common

module API_Bindings = MisskeyJS_API_Bindings
module Client = MisskeyJS_Client

// Internal: Error handler
let handleError = (error: exn): result<'a, [> #APIError(apiError) | #UnknownError(exn)]> => {
  switch isAPIError(error) {
  | Some(apiErr) => Error(#APIError(apiErr))
  | None => Error(#UnknownError(error))
  }
}

// ============================================================
// Meta - Server information
// ============================================================

module Meta = {
  // Get server metadata
  let get = async (client: Client.t, ~detail: bool=false, ()): result<
    JSON.t,
    [> #APIError(apiError) | #UnknownError(exn)],
  > => {
    try {
      let result = await Client.request(
        client,
        ~endpoint="meta",
        ~params=JSON.Encode.object(Dict.fromArray([("detail", JSON.Encode.bool(detail))])),
      )
      Ok(result)
    } catch {
    | error => handleError(error)
    }
  }
}

// ============================================================
// Users - User lookup and information
// ============================================================

module Users = {
  // Get user by ID
  let show = async (client: Client.t, ~userId: id): result<
    JSON.t,
    [> #APIError(apiError) | #UnknownError(exn)],
  > => {
    try {
      let result = await Client.request(
        client,
        ~endpoint="users/show",
        ~params=JSON.Encode.object(Dict.fromArray([("userId", JSON.Encode.string(userId))])),
      )
      Ok(result)
    } catch {
    | error => handleError(error)
    }
  }

  // Get user by username (and optional host for remote users)
  let showByName = async (client: Client.t, ~username: string, ~host: option<string>=?, ()): result<
    JSON.t,
    [> #APIError(apiError) | #UnknownError(exn)],
  > => {
    let obj = Dict.make()
    obj->Dict.set("username", JSON.Encode.string(username))
    host->Option.forEach(h => obj->Dict.set("host", JSON.Encode.string(h)))

    try {
      let result = await Client.request(
        client,
        ~endpoint="users/show",
        ~params=JSON.Encode.object(obj),
      )
      Ok(result)
    } catch {
    | error => handleError(error)
    }
  }

  // Parameters for fetching user notes
  type notesParams = {
    limit?: int,
    sinceId?: id,
    untilId?: id,
    sinceDate?: int,
    untilDate?: int,
    includeReplies?: bool,
    withFiles?: bool,
    withRenotes?: bool,
  }

  // Get notes by a user
  let notes = async (client: Client.t, ~userId: id, ~params: notesParams={}, ()): result<
    array<JSON.t>,
    [> #APIError(apiError) | #UnknownError(exn)],
  > => {
    let obj = Dict.make()
    obj->Dict.set("userId", JSON.Encode.string(userId))
    params.limit->Option.forEach(v => obj->Dict.set("limit", JSON.Encode.int(v)))
    params.sinceId->Option.forEach(v => obj->Dict.set("sinceId", JSON.Encode.string(v)))
    params.untilId->Option.forEach(v => obj->Dict.set("untilId", JSON.Encode.string(v)))
    params.sinceDate->Option.forEach(v => obj->Dict.set("sinceDate", JSON.Encode.int(v)))
    params.untilDate->Option.forEach(v => obj->Dict.set("untilDate", JSON.Encode.int(v)))
    params.includeReplies->Option.forEach(v => obj->Dict.set("includeReplies", JSON.Encode.bool(v)))
    params.withFiles->Option.forEach(v => obj->Dict.set("withFiles", JSON.Encode.bool(v)))
    params.withRenotes->Option.forEach(v => obj->Dict.set("withRenotes", JSON.Encode.bool(v)))

    try {
      let result = await Client.request(
        client,
        ~endpoint="users/notes",
        ~params=JSON.Encode.object(obj),
      )
      Ok(result->Obj.magic)
    } catch {
    | error => handleError(error)
    }
  }
}

// ============================================================
// Following - Follow/unfollow operations
// ============================================================

module Following = {
  // Follow a user
  let create = async (client: Client.t, ~userId: id): result<
    JSON.t,
    [> #APIError(apiError) | #UnknownError(exn)],
  > => {
    try {
      let result = await Client.request(
        client,
        ~endpoint="following/create",
        ~params=JSON.Encode.object(Dict.fromArray([("userId", JSON.Encode.string(userId))])),
      )
      Ok(result)
    } catch {
    | error => handleError(error)
    }
  }

  // Unfollow a user
  let delete = async (client: Client.t, ~userId: id): result<
    JSON.t,
    [> #APIError(apiError) | #UnknownError(exn)],
  > => {
    try {
      let result = await Client.request(
        client,
        ~endpoint="following/delete",
        ~params=JSON.Encode.object(Dict.fromArray([("userId", JSON.Encode.string(userId))])),
      )
      Ok(result)
    } catch {
    | error => handleError(error)
    }
  }
}

// ============================================================
// Drive - File and folder management
// ============================================================

module Drive = {
  // Parameters for listing files
  type filesParams = {
    limit?: int,
    sinceId?: id,
    untilId?: id,
    folderId?: id,
    type_?: string,
  }

  // List files in drive
  let files = async (client: Client.t, ~params: filesParams={}, ()): result<
    array<JSON.t>,
    [> #APIError(apiError) | #UnknownError(exn)],
  > => {
    let obj = Dict.make()
    params.limit->Option.forEach(v => obj->Dict.set("limit", JSON.Encode.int(v)))
    params.sinceId->Option.forEach(v => obj->Dict.set("sinceId", JSON.Encode.string(v)))
    params.untilId->Option.forEach(v => obj->Dict.set("untilId", JSON.Encode.string(v)))
    params.folderId->Option.forEach(v => obj->Dict.set("folderId", JSON.Encode.string(v)))
    params.type_->Option.forEach(v => obj->Dict.set("type", JSON.Encode.string(v)))

    try {
      let result = await Client.request(
        client,
        ~endpoint="drive/files",
        ~params=JSON.Encode.object(obj),
      )
      Ok(result->Obj.magic)
    } catch {
    | error => handleError(error)
    }
  }

  // Upload a file
  // Note: This requires multipart/form-data which may need special handling
  let createFile = async (
    client: Client.t,
    ~file: Blob.t,
    ~name: option<string>=?,
    ~folderId: option<id>=?,
    ~comment: option<string>=?,
    ~isSensitive: option<bool>=?,
    ~force: option<bool>=?,
    (),
  ): result<JSON.t, [> #APIError(apiError) | #UnknownError(exn)]> => {
    let params: API_Bindings.driveFilesCreateParams = {
      file,
      ?name,
      ?folderId,
      ?comment,
      ?isSensitive,
      ?force,
    }

    try {
      let result = await API_Bindings.requestDriveFilesCreate(Client.apiClient(client), ~params)
      Ok(result)
    } catch {
    | error => handleError(error)
    }
  }

  // Delete a file
  let deleteFile = async (client: Client.t, ~fileId: id): result<
    unit,
    [> #APIError(apiError) | #UnknownError(exn)],
  > => {
    try {
      let _ = await Client.request(
        client,
        ~endpoint="drive/files/delete",
        ~params=JSON.Encode.object(Dict.fromArray([("fileId", JSON.Encode.string(fileId))])),
      )
      Ok()
    } catch {
    | error => handleError(error)
    }
  }

  // Create a folder
  let createFolder = async (client: Client.t, ~name: string, ~parentId: option<id>=?, ()): result<
    JSON.t,
    [> #APIError(apiError) | #UnknownError(exn)],
  > => {
    let obj = Dict.make()
    obj->Dict.set("name", JSON.Encode.string(name))
    parentId->Option.forEach(v => obj->Dict.set("parentId", JSON.Encode.string(v)))

    try {
      let result = await Client.request(
        client,
        ~endpoint="drive/folders/create",
        ~params=JSON.Encode.object(obj),
      )
      Ok(result)
    } catch {
    | error => handleError(error)
    }
  }
}
