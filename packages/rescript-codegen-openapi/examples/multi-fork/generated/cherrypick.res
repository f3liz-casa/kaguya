  // Extension Endpoints

  module Account = {
        type post___blocking___createrequest = {
          userid: string,
        }

        let post___blocking___createrequestschemaSchema = S.object(s => {
            userid: s.field("userId", S.string),
          })

        type post___blocking___createresponse = userdetailednotme

        let post___blocking___createresponseschema = userdetailednotmeSchema

        // blocking/create
        let post___blocking___create = (~body, ~fetch): promise<Post___blocking___createResponse> => {
          let validatedBody = bodySchema->S.parseOrThrow(body)

          fetch(
            ~url="/blocking/create",
            ~method_="POST",
            ~body=validatedBody,
          )->Promise.then(response => {
          let validatedResponse = responseSchema->S.parseOrThrow(response)
          validatedResponse
            Promise.resolve(response)
          })
        }

