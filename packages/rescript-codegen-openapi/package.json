{
  "name": "rescript-codegen-openapi",
  "version": "0.1.0",
  "description": "Generate ReScript code with Sury schemas from OpenAPI 3.1 specs. Supports multiple forks with diff/merge capabilities.",
  "keywords": [
    "rescript",
    "openapi",
    "codegen",
    "sury",
    "schema",
    "misskey",
    "api",
    "generator"
  ],
  "author": "",
  "license": "MIT",
  "scripts": {
    "build": "rescript",
    "clean": "rescript clean",
    "watch": "rescript build -w",
    "test": "node --test"
  },
  "main": "src/Codegen.mjs",
  "type": "module",
  "dependencies": {
    "sury": "11.0.0-alpha.4",
    "@readme/openapi-parser": "^5.5.0"
  },
  "devDependencies": {
    "rescript": "^12.1.0"
  },
  "peerDependencies": {
    "rescript": "^12.0.0"
  }
}
