{
  "name": "kaguya-app",
  "version": "0.1.0",
  "description": "A ReScript + Preact Misskey frontend that supports any instance",
  "type": "module",
  "license": "MPL-2.0",
  "scripts": {
    "dev": "concurrently \"rescript build -w\" \"vite\"",
    "build:res": "rescript",
    "build:vite": "vite build",
    "build": "rescript && vite build",
    "clean": "rescript clean && rm -rf dist",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "deploy:dev": "npm run build && wrangler deploy --env dev",
    "cf:dev": "wrangler dev",
    "cf:pages": "wrangler pages dev dist"
  },
  "dependencies": {
    "@preact/signals": "^1.3.1",
    "preact": "^10.25.4",
    "rescript-misskey": "file:../rescript-misskey",
    "rescript-mfm": "file:../rescript-mfm",
    "wouter-preact": "^3.3.5"
  },
  "devDependencies": {
    "@jihchi/vite-plugin-rescript": "^7.2.0",
    "@preact/preset-vite": "^2.9.4",
    "@rescript/core": "^1.6.1",
    "concurrently": "^9.1.2",
    "rescript": "^11.1.4",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "wrangler": "^3.94.0"
  }
}
