{
  "name": "kaguya-app",
  "version": "0.1.0",
  "description": "A ReScript + Preact Misskey frontend that supports any instance",
  "type": "module",
  "license": "MPL-2.0",
  "scripts": {
    "dev": "vite",
    "build:res": "rescript",
    "build:vite": "vite build",
    "build": "rescript && vite build",
    "clean": "rescript clean && rm -rf dist",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "deploy:dev": "npm run build && wrangler deploy --env dev",
    "cf:dev": "wrangler dev",
    "cf:pages": "wrangler pages dev dist"
  },
  "dependencies": {
    "@f3liz/rescript-misskey-api": "file:../../../rescript-misskey-api",
    "@iconify-json/tabler": "^1.2.27",
    "@preact/signals": "^1.3.1",
    "budoux": "^0.7.0",
    "iconify-icon": "^3.0.2",
    "kaguya-network": "file:../kaguya-network",
    "openid-client": "^6.8.2",
    "preact": "^10.25.4",
    "rescript-mfm": "file:../rescript-mfm",
    "wouter-preact": "^3.3.5"
  },
  "devDependencies": {
    "@jihchi/vite-plugin-rescript": "8.0.0-beta.2",
    "@preact/preset-vite": "^2.9.4",
    "@unocss/preset-attributify": "^66.6.0",
    "@unocss/reset": "^66.6.0",
    "concurrently": "^9.1.2",
    "rescript": "^12.1.0",
    "serwist": "^9.5.6",
    "typescript": "^5.7.3",
    "unocss": "^66.6.0",
    "vite": "^6.0.7",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-wasm": "^3.5.0",
    "wrangler": "^4.62.0"
  }
}
